chaosbear-roll = { $player } rolled { $roll }.
chaosbear-position-you = You reached square { $position }, { $gap } squares ahead of the bear.
chaosbear-position-other = { $player } reached square { $position }, { $gap } squares ahead of the bear.
chaosbear-position = { $player } is now at square { $position }.

chaosbear-draw-card-you = You draw a chaos card.
chaosbear-draw-card-other = { $player } draws a chaos card.
chaosbear-draws-card = { $player } draws a card.
chaosbear-card-impulsion-you = Impulsion! You surge ahead to square { $position }, { $gap } squares ahead of the bear.
chaosbear-card-impulsion-other = Impulsion! { $player } surges ahead to square { $position }, { $gap } squares ahead of the bear.
